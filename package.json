    "mpcp-service": "file:../mpcp-reference"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.0.0",
    "express": "^5.1.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
